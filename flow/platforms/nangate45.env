# Educational OpenROAD platform based on the Nangate45 collateral bundled
# with the local OpenROAD source checkout.

PLATFORM="nangate45"
NANGATE45_ROOT="${PROJECT_ROOT}/.local/src/OpenROAD/test/Nangate45"

LIBERTY="${NANGATE45_ROOT}/Nangate45_typ.lib"
LEF_FILES=(
  "${NANGATE45_ROOT}/Nangate45_tech.lef"
  "${NANGATE45_ROOT}/Nangate45_stdcell.lef"
)
RC_FILE="${NANGATE45_ROOT}/Nangate45.rc"

SITE="FreePDK45_38x28_10R_NP_162NW_34O"
SIGNAL_ROUTING_LAYERS="metal2-metal10"
CLOCK_ROUTING_LAYERS="metal3-metal10"
WIRE_RC_LAYER="metal3"
CLOCK_RC_LAYER="metal5"
IO_H_LAYER="metal3"
IO_V_LAYER="metal2"
PLACE_DENSITY="0.55"

# Microns. Override these in a block flow.env for larger designs.
DIE_AREA="0 0 120 120"
CORE_AREA="10 10 110 110"
