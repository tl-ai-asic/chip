# Run from the repository root:
#   yosys -s ip/riscv32im_core/synth/yosys_riscv32im_core_v1.ys

read_verilog -sv -DSYNTHESIS ip/riscv32im_core/logic_v1/riscv32im_types.sv
read_verilog -sv -DSYNTHESIS ip/riscv32im_core/logic_v1/riscv32im_alu.sv
read_verilog -sv -DSYNTHESIS ip/riscv32im_core/logic_v1/riscv32im_muldiv.sv
read_verilog -sv -DSYNTHESIS ip/riscv32im_core/logic_v1/riscv32im_decode.sv
read_verilog -sv -DSYNTHESIS ip/riscv32im_core/logic_v1/riscv32im_csr_read.sv
read_verilog -sv -DSYNTHESIS ip/riscv32im_core/logic_v1/riscv32im_lsu_format.sv
read_verilog -sv -DSYNTHESIS ip/riscv32im_core/logic_v1/riscv32im_lsu.sv
read_verilog -sv -DSYNTHESIS ip/riscv32im_core/logic_v1/riscv32im_core.sv

hierarchy -check -top riscv32im_core
proc
opt
fsm
opt
memory
opt
techmap
opt

stat
