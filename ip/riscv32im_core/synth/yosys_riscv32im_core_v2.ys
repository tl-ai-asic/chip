# Run from the repository root:
#   yosys -s ip/riscv32im_core/synth/yosys_riscv32im_core_v2.ys

read_verilog -sv -DSYNTHESIS ip/riscv32im_core/logic_v2/riscv32im_scoreboard_types.sv
read_verilog -sv -DSYNTHESIS ip/riscv32im_core/logic_v2/riscv32im_alu.sv
read_verilog -sv -DSYNTHESIS ip/riscv32im_core/logic_v2/riscv32im_muldiv.sv
read_verilog -sv -DSYNTHESIS ip/riscv32im_core/logic_v2/riscv32im_decode.sv
read_verilog -sv -DSYNTHESIS ip/riscv32im_core/logic_v2/riscv32im_csr_read.sv
read_verilog -sv -DSYNTHESIS ip/riscv32im_core/logic_v2/riscv32im_csr_file.sv
read_verilog -sv -DSYNTHESIS ip/riscv32im_core/logic_v2/riscv32im_issue_prepare.sv
read_verilog -sv -DSYNTHESIS ip/riscv32im_core/logic_v2/riscv32im_alu_execute.sv
read_verilog -sv -DSYNTHESIS ip/riscv32im_core/logic_v2/riscv32im_lsu_format.sv
read_verilog -sv -DSYNTHESIS ip/riscv32im_core/logic_v2/riscv32im_lsu.sv
read_verilog -sv -DSYNTHESIS ip/riscv32im_core/logic_v2/riscv32im_scoreboard.sv
read_verilog -sv -DSYNTHESIS ip/riscv32im_core/logic_v2/riscv32im_rvfi_trace.sv
read_verilog -sv -DSYNTHESIS ip/riscv32im_core/logic_v2/riscv32im_core.sv

