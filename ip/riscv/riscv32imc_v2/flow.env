# Block-level reusable OpenROAD flow configuration.

source "${PROJECT_ROOT}/flow/platforms/nangate45.env"

BLOCK="riscv32imc_v2"
TOP="riscv32im_core"

RTL_FILES=(
  "${PROJECT_ROOT}/ip/riscv/riscv32imc_v2/logic/riscv32im_types.sv"
  "${PROJECT_ROOT}/ip/riscv/riscv32imc_v2/logic/riscv32im_alu.sv"
  "${PROJECT_ROOT}/ip/riscv/riscv32imc_v2/logic/riscv32im_muldiv.sv"
  "${PROJECT_ROOT}/ip/riscv/riscv32imc_v2/logic/riscv32im_decode.sv"
  "${PROJECT_ROOT}/ip/riscv/riscv32imc_v2/logic/riscv32im_prefetch.sv"
  "${PROJECT_ROOT}/ip/riscv/riscv32imc_v2/logic/riscv32im_csr_read.sv"
  "${PROJECT_ROOT}/ip/riscv/riscv32imc_v2/logic/riscv32im_csr_file.sv"
  "${PROJECT_ROOT}/ip/riscv/riscv32imc_v2/logic/riscv32im_issue_prepare.sv"
  "${PROJECT_ROOT}/ip/riscv/riscv32imc_v2/logic/riscv32im_alu_execute.sv"
  "${PROJECT_ROOT}/ip/riscv/riscv32imc_v2/logic/riscv32im_lsu_format.sv"
  "${PROJECT_ROOT}/ip/riscv/riscv32imc_v2/logic/riscv32im_lsu.sv"
  "${PROJECT_ROOT}/ip/riscv/riscv32imc_v2/logic/riscv32im_rvfi_trace.sv"
  "${PROJECT_ROOT}/ip/riscv/riscv32imc_v2/logic/riscv32im_writeback_router.sv"
  "${PROJECT_ROOT}/ip/riscv/riscv32imc_v2/logic/riscv32im_register_file.sv"
  "${PROJECT_ROOT}/ip/riscv/riscv32imc_v2/logic/riscv32im_core.sv"
)

CLOCK_PORT="clk"
CLOCK_PERIOD_NS="10.0"
RESET_PORT="rst_n"
RESET_RELEASE_SYNCHRONIZED="1"
REPAIR_MAX_WIRE_LENGTH="120"
REPAIR_TIMING_SETUP="1"

DIE_AREA="0 0 900 900"
CORE_AREA="40 40 860 860"
