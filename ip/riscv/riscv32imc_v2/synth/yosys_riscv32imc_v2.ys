# Run from the repository root:
#   yosys -s ip/riscv/riscv32imc_v2/synth/yosys_riscv32imc_v2.ys

read_verilog -sv -DSYNTHESIS ip/riscv/riscv32imc_v2/logic/riscv32im_types.sv
read_verilog -sv -DSYNTHESIS ip/riscv/riscv32imc_v2/logic/riscv32im_alu.sv
read_verilog -sv -DSYNTHESIS ip/riscv/riscv32imc_v2/logic/riscv32im_muldiv.sv
read_verilog -sv -DSYNTHESIS ip/riscv/riscv32imc_v2/logic/riscv32im_decode.sv
read_verilog -sv -DSYNTHESIS ip/riscv/riscv32imc_v2/logic/riscv32im_prefetch.sv
read_verilog -sv -DSYNTHESIS ip/riscv/riscv32imc_v2/logic/riscv32im_csr_read.sv
read_verilog -sv -DSYNTHESIS ip/riscv/riscv32imc_v2/logic/riscv32im_csr_file.sv
read_verilog -sv -DSYNTHESIS ip/riscv/riscv32imc_v2/logic/riscv32im_issue_prepare.sv
read_verilog -sv -DSYNTHESIS ip/riscv/riscv32imc_v2/logic/riscv32im_alu_execute.sv
read_verilog -sv -DSYNTHESIS ip/riscv/riscv32imc_v2/logic/riscv32im_lsu_format.sv
read_verilog -sv -DSYNTHESIS ip/riscv/riscv32imc_v2/logic/riscv32im_lsu.sv
read_verilog -sv -DSYNTHESIS ip/riscv/riscv32imc_v2/logic/riscv32im_rvfi_trace.sv
read_verilog -sv -DSYNTHESIS ip/riscv/riscv32imc_v2/logic/riscv32im_core.sv

hierarchy -check -top riscv32im_core
proc
opt
fsm
opt
memory
opt
techmap
opt

stat
write_json ip/riscv/riscv32imc_v2/synth/riscv32imc_v2_netlist.json
