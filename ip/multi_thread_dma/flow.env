# Block-level reusable OpenROAD flow configuration.

source "${PROJECT_ROOT}/flow/platforms/nangate45.env"

BLOCK="multi_thread_dma"
TOP="multi_thread_dma"

RTL_FILES=(
  "${PROJECT_ROOT}/ip/multi_thread_dma/logic/multi_thread_dma_id_pool.sv"
  "${PROJECT_ROOT}/ip/multi_thread_dma/logic/multi_thread_dma_reorder_buffer.sv"
  "${PROJECT_ROOT}/ip/multi_thread_dma/logic/multi_thread_dma.sv"
)

CLOCK_PORT="clk"
CLOCK_PERIOD_NS="10.0"
RESET_PORT="rst_n"
RESET_RELEASE_SYNCHRONIZED="1"
